# ============================================
# CareerOS — Environment Configuration
# ============================================

# --- General ---
NODE_ENV=development
PORT=3000

# --- Database (PostgreSQL) ---
DATABASE_URL=postgresql://career_os:career_os_dev@localhost:5432/career_os?schema=public

# --- Redis ---
REDIS_URL=redis://localhost:6379

# --- Auth ---
JWT_SECRET=change-me-in-production
JWT_EXPIRATION=7d
LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=
LINKEDIN_CALLBACK_URL=http://localhost:3000/api/auth/linkedin/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=http://localhost:3000/api/auth/google/callback

# --- AI / LLM ---
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o
OPENAI_EMBEDDING_MODEL=text-embedding-3-large

# --- Vector DB (Pinecone) ---
PINECONE_API_KEY=
PINECONE_ENVIRONMENT=
PINECONE_INDEX=career-os

# --- Object Storage (S3-compatible) ---
S3_BUCKET=career-os-uploads
S3_REGION=eu-west-2
S3_ACCESS_KEY=
S3_SECRET_KEY=
S3_ENDPOINT=

# --- Email ---
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=

# --- Observability ---
LOG_LEVEL=debug
