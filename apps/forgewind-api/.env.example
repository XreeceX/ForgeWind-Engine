# Neon (pooled connection string — use your own from the Neon console)
DATABASE_URL=postgresql://USER:PASSWORD@ep-xxx.region.aws.neon.tech/neondb?sslmode=require

# GitHub OAuth (for later frontend / full auth)
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITHUB_CALLBACK_URL=

# GitHub API (optional; improves rate limits for repo sync)
GITHUB_TOKEN=

# AI (narrative generation)
ANTHROPIC_API_KEY=
# Optional override; stored in DB as model_version on generated rows
ANTHROPIC_MODEL=claude-3-5-sonnet-20241022

# App
PORT=3001
NODE_ENV=development

# CORS (comma-separated origins)
CORS_ORIGIN=http://localhost:3000
