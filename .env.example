# ============================================
# CareerOS Forge Engine — Environment Configuration
# ============================================

# --- General ---
NODE_ENV=development
PORT=3000

# --- Database (PostgreSQL) ---
DATABASE_URL=postgresql://careeros_forge:careeros_forge_dev@localhost:5432/careeros_forge?schema=public

# --- Redis ---
REDIS_URL=redis://localhost:6379

# --- Auth ---
JWT_SECRET=change-me-in-production
JWT_EXPIRATION=7d
LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=
LINKEDIN_CALLBACK_URL=http://localhost:3000/api/auth/linkedin/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=http://localhost:3000/api/auth/google/callback

# --- AI / LLM ---
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o
OPENAI_EMBEDDING_MODEL=text-embedding-3-large

# --- GitHub Integration ---
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITHUB_REDIRECT_URI=http://localhost:4010/api/v1/github/callback
GITHUB_SCOPE=repo read:user
# 32-byte key in hex (64 chars)
GITHUB_TOKEN_ENCRYPTION_KEY=

# --- Service URLs (Phase 2) ---
REPO_ANALYSIS_SERVICE_URL=http://localhost:4011/api/v1
CONTENT_SERVICE_URL=http://localhost:4012/api/v1
WORKFLOW_SERVICE_URL=http://localhost:4013/api/v1
NEXT_PUBLIC_INTEGRATION_SERVICE_URL=http://localhost:4010/api/v1
NEXT_PUBLIC_CONTENT_SERVICE_URL=http://localhost:4012/api/v1
NEXT_PUBLIC_WORKFLOW_SERVICE_URL=http://localhost:4013/api/v1

# --- Vector DB (Pinecone) ---
PINECONE_API_KEY=
PINECONE_ENVIRONMENT=
PINECONE_INDEX=careeros-forge

# --- Object Storage (S3-compatible) ---
S3_BUCKET=careeros-forge-uploads
S3_REGION=eu-west-2
S3_ACCESS_KEY=
S3_SECRET_KEY=
S3_ENDPOINT=

# --- Email ---
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=

# --- Observability ---
LOG_LEVEL=debug
