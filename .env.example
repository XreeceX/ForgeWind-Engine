# ============================================
# ForgeWind Engine — Environment Configuration
# ============================================

# --- General ---
NODE_ENV=development
# Leave PORT unset here; Next uses apps/web dev script. ForgeWind API: apps/forgewind-api/.env sets PORT=3001.
CORS_ORIGIN=http://localhost:3000

# --- Database (PostgreSQL) ---
# Neon pooled example: postgresql://USER:PASS@ep-xxx.region.aws.neon.tech/neondb?sslmode=require
# Vercel Neon Storage: if DATABASE_URL already exists, the integration may set STORAGE_URL instead.
DATABASE_URL=postgresql://forgewind:forgewind_dev@localhost:5432/forgewind?schema=public
# STORAGE_URL=

# --- Redis ---
REDIS_URL=redis://localhost:6379

# --- Auth ---

JWT_SECRET=change-me-in-production
JWT_EXPIRATION=7d
NEXTAUTH_SECRET=change-me-in-production
NEXTAUTH_URL=http://localhost:3000
LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=
LINKEDIN_CALLBACK_URL=http://localhost:3000/api/auth/linkedin/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=http://localhost:3000/api/auth/google/callback

# --- AI / LLM ---
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o
OPENAI_EMBEDDING_MODEL=text-embedding-3-large
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-3-5-sonnet-20241022

# --- GitHub Integration ---
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITHUB_REDIRECT_URI=http://localhost:4010/api/v1/github/callback
GITHUB_CALLBACK_URL=
GITHUB_SCOPE=repo read:user
GITHUB_TOKEN=
# 32-byte key in hex (64 chars)
GITHUB_TOKEN_ENCRYPTION_KEY=

# --- Apps / Web (Next.js) ---
# ForgeWind API base URL for the Next.js app (no /api prefix; Nest listens on this host)
NEXT_PUBLIC_FORGEWIND_API_URL=http://localhost:3001
# Legacy gateway (optional)
NEXT_PUBLIC_API_URL=http://localhost:4000/api/v1
# --- Service URLs (Phase 2) ---
REPO_ANALYSIS_SERVICE_URL=http://localhost:4011/api/v1
CONTENT_SERVICE_URL=http://localhost:4012/api/v1
WORKFLOW_SERVICE_URL=http://localhost:4013/api/v1
NEXT_PUBLIC_INTEGRATION_SERVICE_URL=http://localhost:4010/api/v1
NEXT_PUBLIC_CONTENT_SERVICE_URL=http://localhost:4012/api/v1
NEXT_PUBLIC_WORKFLOW_SERVICE_URL=http://localhost:4013/api/v1

# --- Vector DB (Pinecone) ---
PINECONE_API_KEY=
PINECONE_ENVIRONMENT=
PINECONE_INDEX=forgewind

# --- Object Storage (S3-compatible) ---
S3_BUCKET=forgewind-uploads
S3_REGION=eu-west-2
S3_ACCESS_KEY=
S3_SECRET_KEY=
S3_ENDPOINT=

# --- Email ---
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=

# --- Observability ---
LOG_LEVEL=debug

# --- Ops (ForgeWind API + Neon) ---
# Apply Drizzle schema to Neon (from repo root): pnpm db:forgewind:migrate
# API CORS: set CORS_ORIGIN to your deployed Next.js origin (e.g. https://app.example.com)
# Vercel web + API: duplicate DATABASE_URL/STORAGE_URL on the API host; set NEXT_PUBLIC_FORGEWIND_API_URL to the public API URL
